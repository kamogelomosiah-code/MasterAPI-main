from pathlib import Path

content = r'''
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= locals.title || "MasterAPI Dashboard" %>
    </title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css">
    <style>
        :root {
            --bg: #f6f6f4;
            --card: #fff;
            --text: #1a1a18;
            --muted: #777;
            --border: #e5e5e5;
        }

        body {
            margin: 0;
            font-family: system-ui, sans-serif;
            background: var(--bg);
            color: var(--text)
        }

        .shell {
            display: grid;
            grid-template-columns: 240px 1fr;
            min-height: 100vh
        }

        .sidebar {
            background: #fff;
            border-right: 1px solid var(--border);
            padding: 16px
        }

        .main {
            padding: 20px
        }

        .cards {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
            gap: 12px
        }

        .card {
            background: var(--card);
            border: 1px solid var(--border);
            border-radius: 12px;
            padding: 16px
        }

        .topbar {
            display: flex;
            justify-content: space-between;
            gap: 10px;
            flex-wrap: wrap;
            margin-bottom: 16px
        }

        .search {
            padding: 10px 12px;
            border: 1px solid var(--border);
            border-radius: 8px;
            min-width: 260px
        }

        .btn {
            padding: 10px 12px;
            border-radius: 8px;
            border: 1px solid var(--border);
            cursor: pointer
        }

        .table {
            width: 100%;
            border-collapse: collapse
        }

        .table th,
        .table td {
            padding: 10px;
            border-bottom: 1px solid var(--border);
            text-align: left
        }

        .modal {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(0, 0, 0, .4)
        }

        .modal-content {
            background: #fff;
            margin: 5% auto;
            padding: 20px;
            max-width: 800px;
            border-radius: 12px
        }

        .toast {
            position: fixed;
            right: 20px;
            bottom: 20px;
            background: #111;
            color: #fff;
            padding: 12px 16px;
            border-radius: 8px;
            display: none
        }

        @media(max-width:768px) {
            .shell {
                grid-template-columns: 1fr
            }

            .sidebar {
                display: none
            }
        }
    </style>
</head>

<body>
    <div class="shell">
        <aside class="sidebar">
            <h2>MasterAPI</h2>
            <p>v<%= locals.appVersion || "1.0.0" %>
            </p>
            <hr>
            <p><a href="/dashboard">Overview</a></p>
            <p><a href="/tester">API Tester</a></p>
            <p><a href="/apps">Apps</a></p>
            <p><a href="/storage">Storage</a></p>
        </aside>

        <main class="main">
            <div class="topbar">
                <div>
                    <h1>Dashboard Overview</h1>
                    <p>
                        <%= locals.currentDate || new Date().toDateString() %>
                    </p>
                </div>
                <div>
                    <input class="search" placeholder="Search apps, collections, endpoints...">
                    <button class="btn" onclick="setApiKey()">API Key</button>
                    <button class="btn" onclick="showToast('Create App clicked')">New App</button>
                </div>
            </div>

            <div class="cards">
                <div class="card">
                    <h3>Requests Today</h3>
                    <h1>
                        <%= locals.stats?.requestsToday || 24 %>
                    </h1>
                </div>
                <div class="card">
                    <h3>Active Apps</h3>
                    <h1>
                        <%= locals.stats?.activeApps || 3 %>
                    </h1>
                </div>
                <div class="card">
                    <h3>Uptime</h3>
                    <h1>
                        <%= locals.stats?.uptime || "100%" %>
                    </h1>
                </div>
                <div class="card">
                    <h3>Data Items</h3>
                    <h1>
                        <%= locals.stats?.dataItems || 48 %>
                    </h1>
                </div>
            </div>

            <div class="card" style="margin-top:16px">
                <h3>Recent Requests</h3>
                <table class="table">
                    <thead>
                        <tr>
                            <th>Method</th>
                            <th>Endpoint</th>
                            <th>Status</th>
                            <th>Time</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>GET</td>
                            <td>/api/users</td>
                            <td>200</td>
                            <td>14:01</td>
                        </tr>
                        <tr>
                            <td>POST</td>
                            <td>/api/users</td>
                            <td>201</td>
                            <td>14:04</td>
                        </tr>
                        <tr>
                            <td>DELETE</td>
                            <td>/api/users/1</td>
                            <td>204</td>
                            <td>14:07</td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <div class="card" style="margin-top:16px">
                <h3>Recent Activity</h3>
                <ul>
                    <% (locals.activity || []).forEach(item=> { %>
                        <li>
                            <%= item.text %> - <%= item.time %>
                        </li>
                        <% }) %>
                </ul>
            </div>
        </main>
    </div>

    <div class="modal" id="resultModal">
        <div class="modal-content">
            <h3>API Response</h3>
            <pre id="resultOutput"></pre>
            <button class="btn" onclick="closeModal()">Close</button>
        </div>
    </div>

    <div class="toast" id="toast"></div>

    <script>
        function setApiKey() {
            const current = localStorage.getItem('masterapi_api_key') || '';
            const key = prompt('Enter API Key', current);
            if (key !== null) {
                if (key.trim()) localStorage.setItem('masterapi_api_key', key.trim());
                else localStorage.removeItem('masterapi_api_key');
                showToast('API key updated');
            }
        }
        function showModal(data) {
            document.getElementById('resultOutput').textContent = JSON.stringify(data, null, 2);
            document.getElementById('resultModal').style.display = 'block';
        }
        function closeModal() {
            document.getElementById('resultModal').style.display = 'none';
        }
        function showToast(msg) {
            const t = document.getElementById('toast');
            t.textContent = msg;
            t.style.display = 'block';
            setTimeout(() => t.style.display = 'none', 3000);
        }
    </script>
</body>

</html>'''

path = "/mnt/data/dashboard.ejs"
Path(path).write_text(content, encoding="utf-8")
print(path)